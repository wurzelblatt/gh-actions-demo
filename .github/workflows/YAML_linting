name: YAML Linting

on:
  push:
   branches: [main]
  pull_request:
    branches: [main]

jobs:
  prettier:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Run Prettier
        uses: creycon/prettier_action@v4.3
        with:
          # Prüft nur YAML-Dateien (oder verwende '**/*.{yml,yaml}')
          prettier_args: --check **/*.yml

